# Environment example for Property Dealer CRM
# Copy to `.env.local` and fill in real values for local development

MONGODB_URI=mongodb://localhost:27017/property_crm
SESSION_SECRET=your-base64-encoded-32-byte-secret-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — Email notifications (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
